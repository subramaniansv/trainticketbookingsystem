<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <servlet>
        <servlet-name>TrainController</servlet-name>
        <servlet-class>com.trainticket.app.module.train.TrainController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>TrainController</servlet-name>
        <url-pattern>/api/trains/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>StationController</servlet-name>
        <servlet-class>com.trainticket.app.module.station.StationController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>StationController</servlet-name>
        <url-pattern>/api/station/*</url-pattern>
    </servlet-mapping>
 <servlet>
            <servlet-name>RouteController</servlet-name>
        <servlet-class>com.trainticket.app.module.station.RouteController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RouteController</servlet-name>
        <url-pattern>/api/route/*</url-pattern>
    </servlet-mapping>

     <servlet>
            <servlet-name>ScheduleController</servlet-name>
        <servlet-class>com.trainticket.app.module.schedule.ScheduleController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ScheduleController</servlet-name>
        <url-pattern>/api/time/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserController</servlet-name>
        <servlet-class>com.trainticket.app.module.user.UserController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UserController</servlet-name>
        <url-pattern>/api/user/*</url-pattern>
    </servlet-mapping>

    <servlet>
            <servlet-name>AuthController</servlet-name>
        <servlet-class>com.trainticket.app.module.auth.AuthController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AuthController</servlet-name>
        <url-pattern>/api/auth/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TatkalController</servlet-name>
        <servlet-class>com.trainticket.app.module.booking.TatkalBookingController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>TatkalController</servlet-name>
        <url-pattern>/api/tatkal/*</url-pattern>
    </servlet-mapping>
        <servlet>
        <servlet-name>BookingController</servlet-name>
        <servlet-class>com.trainticket.app.module.booking.BookingController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BookingController</servlet-name>
        <url-pattern>/api/booking/*</url-pattern>
    </servlet-mapping>

 <servlet>
        <servlet-name>GeneralTicketBookingController</servlet-name>
        <servlet-class>com.trainticket.app.module.booking.GeneralTicketBookingController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>GeneralTicketBookingController</servlet-name>
        <url-pattern>/api/general/*</url-pattern>
    </servlet-mapping>

</web-app>